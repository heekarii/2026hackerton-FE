          },
          "ai_analysis": {
            "summary": "도서관 냉방 관련 시설 민원입니다.",
            "urgency": "normal",
            "similar_complaints": [
              {
                "id": 1019,
                "title": "강의실 냉방 온도 점검 요청",
                "match_rate": 76
              }
            ]
          }
        }
      }
    },
    {
      "id": "listMyComplaints",
      "method": "GET",
      "path": "/me/complaints",
      "usedBy": ["/mypage"],
      "query": {
        "status": "received|processing|completed",
        "page": 1,
        "limit": 20
      },
      "successResponse": {
        "status": 200,
        "body": {
          "complaints": [
            {
              "id": 1038,
              "title": "도서관 3층 열람실 콘센트 고장",
