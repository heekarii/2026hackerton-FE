{
  "version": "2026-06-24",
  "baseUrlEnv": "VITE_API_BASE_URL",
  "mockModeEnv": "VITE_USE_MOCK_API",
  "auth": {
    "type": "bearer_or_http_only_cookie",
    "header": "Authorization: Bearer <access_token>",
    "credentials": "include"
  },
  "endpoints": [
    {
      "id": "sendEmailVerificationCode",
      "method": "POST",
      "path": "/auth/email-verification/send",
      "usedBy": ["/signup"],
      "request": {
        "contentType": "application/json",
        "body": {
          "email": "minseo@university.ac.kr"
        }
      },
      "successResponse": {
        "status": 200,
        "body": {
          "message": "인증번호를 이메일로 보냈습니다.",
          "expires_in_seconds": 300
        }
      },
      "errorResponse": {
        "status": 400,
        "body": {
          "message": "학교 이메일만 사용할 수 있습니다."
        }
      }
    },
    {
      "id": "verifyEmailCode",
      "method": "POST",
      "path": "/auth/email-verification/verify",
      "usedBy": ["/signup"],
      "request": {
        "contentType": "application/json",
        "body": {
          "email": "minseo@university.ac.kr",
          "code": "123456"
        }
      },
      "successResponse": {
        "status": 200,
        "body": {
          "verified": true,
          "verification_token": "email-verification-token"
        }
      },
      "errorResponse": {
        "status": 400,
        "body": {
          "message": "인증번호가 일치하지 않습니다."
        }
      }
    },
    {
      "id": "signup",
      "method": "POST",
      "path": "/auth/signup",
      "usedBy": ["/signup"],
      "request": {
        "contentType": "application/json",
        "body": {
          "email": "minseo@university.ac.kr",
          "name": "김민서",
          "nickname": "민서",
          "student_id": "20261234",
          "department": "컴퓨터공학과",
          "password": "password1234",
          "verification_token": "email-verification-token"
        }
      },
      "successResponse": {
        "status": 201,
        "body": {
          "id": 2,
          "email": "minseo@university.ac.kr",
          "name": "김민서",
          "nickname": "민서",
          "student_id": "20261234",
          "department": "컴퓨터공학과",
          "message": "회원가입이 완료되었습니다."
        }
      },
      "errorResponse": {
        "status": 409,
        "body": {
          "message": "이미 가입된 이메일입니다."
        }
      }
    },
    {
      "id": "login",
      "method": "POST",
      "path": "/auth/login",
      "usedBy": ["/login"],
      "request": {
        "contentType": "application/json",
        "body": {
          "email": "minseo@university.ac.kr",
          "password": "password1234"
        }
      },
      "successResponse": {
        "status": 200,
        "body": {
          "access_token": "jwt-access-token",
          "token_type": "bearer",
          "user": {
            "id": 1,
            "name": "김민서",
            "nickname": "민서",
            "email": "minseo@university.ac.kr",
            "department": "컴퓨터공학과",
            "student_id": "20261234",
            "role": "complainant"
          }
        }
      },
      "errorResponse": {
        "status": 401,
        "body": {
          "message": "이메일 또는 비밀번호가 올바르지 않습니다."
        }
      }
    },
    {
      "id": "getMe",
      "method": "GET",
      "path": "/me",
      "usedBy": ["/mypage"],
      "successResponse": {
        "status": 200,
        "body": {
          "user": {
            "id": 1,
            "name": "김민서",
            "nickname": "민서",
            "email": "minseo@university.ac.kr",
            "department": "컴퓨터공학과",
            "student_id": "20261234",
            "role": "complainant"
          }
        }
      }
    },
    {
      "id": "createComplaint",
      "method": "POST",
      "path": "/complaints",
      "usedBy": ["/complaint"],
      "request": {
        "contentType": "application/json",
        "body": {
          "title": "중앙도서관 3층 냉방이 너무 약해요",
          "category": "시설",
          "occurred_at": "2026-06-24T05:30:00.000Z",
          "complaint_content": "열람실 냉방이 반복적으로 약해서 장시간 이용이 어렵습니다.",
          "desired_improvement": "냉방 장비 점검과 온도 기준 안내가 필요합니다.",
          "is_anonymous": true,
          "image_names": ["library-ac.jpg"]
        }
      },
      "successResponse": {
        "status": 201,
        "body": {
          "id": 1042,
          "status": "received",
          "message": "민원이 등록됐어요. AI가 분류, 요약, 유사 민원을 분석합니다.",
          "complaint": {
            "id": 1042,
            "title": "중앙도서관 3층 냉방이 너무 약해요",
            "category": "시설",
