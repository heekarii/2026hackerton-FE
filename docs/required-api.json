            "total": 1
          }
        }
      }
    },
    {
      "id": "updateComplaintSatisfaction",
      "method": "PATCH",
      "path": "/complaints/{complaint_id}/satisfaction",
      "usedBy": ["/mypage"],
      "request": {
        "contentType": "application/json",
        "body": {
          "satisfaction": 4
        }
      },
      "successResponse": {
        "status": 200,
        "body": {
          "id": 1024,
          "satisfaction": 4,
          "message": "만족도가 저장되었습니다."
        }
      }
    },
    {
      "id": "getDashboardSummary",
      "method": "GET",
      "path": "/dashboard/summary",
      "usedBy": ["/"],
      "query": {
        "semester": "2026-1",
